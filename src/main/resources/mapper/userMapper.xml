<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.japan.admin.user.mapper.UserMapper">


    <select id="findByUsername" resultType="com.japan.admin.user.entity.SysUser">
        select * from sys_user where username=#{username}
    </select>
</mapper>